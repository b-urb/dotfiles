# ─────────────────────────────────────────────────────────────────────────────
# chezmoi ignore file — patterns match TARGET paths (relative to $HOME)
# This file is a Go template; use if/end blocks for conditional ignores.
# ─────────────────────────────────────────────────────────────────────────────

# Repo-level files that should never be placed in $HOME
README.md
docs/
ansible/
ubuntu/
arch/
macos/
scripts/
templates/
options/
zsh/
kube/
elgato-scripts/
other/
newsboat/
chrome-extensions.json
install_extensions.sh
init.sh
install.conf.yaml
dotbot/
.gitmodules
.checksums
config.yaml
wezterm/wezterm-session-manager/

# ─────────────────────────────────────────────────────────────────────────────
# VSCode runtime data — never manage these with chezmoi
# ─────────────────────────────────────────────────────────────────────────────
.config/vscode/User/globalStorage/
.config/vscode/User/workspaceStorage/
.config/vscode/User/History/
.config/vscode/User/chatEditingSessions/

# ─────────────────────────────────────────────────────────────────────────────
# macOS-only configs
# ─────────────────────────────────────────────────────────────────────────────
{{ if ne .chezmoi.os "darwin" }}
.config/sketchybar/
.config/yabai/
.config/skhd/
.config/spacebar/
.aerospace.toml
{{ end }}

# ─────────────────────────────────────────────────────────────────────────────
# Linux-only configs
# ─────────────────────────────────────────────────────────────────────────────
{{ if ne .chezmoi.os "linux" }}
.config/i3/
.config/sway/
.config/waybar/
{{ end }}

# ─────────────────────────────────────────────────────────────────────────────
# Linux display-server-specific
# ─────────────────────────────────────────────────────────────────────────────
{{ if .isLinux }}
{{ if not .isX11 }}
.config/i3/
{{ end }}
{{ if not .isWayland }}
.config/sway/
.config/waybar/
{{ end }}
{{ end }}

# ─────────────────────────────────────────────────────────────────────────────
# Windows-only: exclude everything except wezterm and codex/opencode configs
# ─────────────────────────────────────────────────────────────────────────────
{{ if .isWindows }}
.config/sketchybar/
.config/yabai/
.config/skhd/
.config/spacebar/
.aerospace.toml
.config/i3/
.config/sway/
.config/waybar/
.config/atuin/
.config/helix/
.config/k9s/
.config/karabiner/
.config/lazygit/
.config/nvim/
.config/zellij/
.config/yazi/
.config/vscode/
.bash_logout
.profile
.bashrc
.zshrc
.kubectl_aliases
.newsboat/
.kube/
.ssh/
.env
.env.darwin
.env.linux
{{ end }}
