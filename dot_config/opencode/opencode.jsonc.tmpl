  "instructions": ["~/.config/opencode/instructions.md"],
  "autoupdate": true,
  "plugin": [
    "notify"
  ],
  "tools": {
    "todoist_*": false
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "todoist-orchestrator": {
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-20250514",
      "description": "Fetches open Todoist tasks, creates git worktrees, delegates to todo-planner per task, collects results, closes completed tasks",
      "prompt": "{file:~/.config/opencode/prompts/orchestrator.txt}",
      "tools": {
        "todoist_*": true,
        "bash": true,
        "question": true,
        "write": false,
        "edit": false
      },
      "permission": {
        "edit": "deny",
        "question": "allow",
        "bash": {
          "*": "ask",
          "git worktree *": "allow",
          "git checkout *": "allow",
          "git branch *": "allow",
          "mkdir *": "allow"
        },
        "task": {
          "*": "deny",
          "todo-planner": "allow"
        }
      }
    }
  }
}
