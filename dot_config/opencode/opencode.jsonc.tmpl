{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration moved to config/opencode/tui.json
  // "theme": "one-dark",
  // "theme": "github_dark_colorblind",
//  "model": "anthropic/claude-sonnet-4-5",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--headless"]
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"]
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {{ (bitwarden "item" "github-pat").login.password }}",
        "X-MCP-Toolsets": "all"
      }
    },
    "pulumi": {
      "type": "remote",
      "url": "https://mcp.ai.pulumi.com/mcp"
    },
    "storybook": {
      "type": "remote",
      "url": "http://localhost:6006/mcp"
    },
    "directus": {
      "type": "remote",
      "url": "https://cms.burbn.de/mcp/",
      "headers": {
        "Authorization": "Bearer {{ (bitwarden "item" "directus-token").login.password }}",
        "X-MCP-Toolsets": "all"
      }
    },
    "kubernetes-readonly": {
      "type": "local",
      "command": ["npx", "mcp-server-kubernetes"],
      "environment": {
        "ALLOW_ONLY_NON_DESTRUCTIVE_TOOLS": "true"
      }
    }
  },
  "autoupdate": true,
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
