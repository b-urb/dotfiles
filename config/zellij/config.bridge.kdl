// Minimal bridge config used for DOTFILES_ZELLIJ_MODE=bridge
// This keeps zellij effectively invisible and keybind-free.

keybinds clear-defaults=true {
    normal {
        bind "Ctrl /" { ToggleFloatingPanes; }
        bind "Ctrl _" { ToggleFloatingPanes; }
    }
    locked {
        bind "Ctrl /" { ToggleFloatingPanes; }
        bind "Ctrl _" { ToggleFloatingPanes; }
    }
}

default_mode "normal"
simplified_ui true
pane_frames false
show_startup_tips false
show_release_notes false
on_force_close "quit"
theme "onedark"
