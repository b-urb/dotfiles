#!/usr/bin/env lua

local source = debug.getinfo(1, "S").source
if source:sub(1, 1) == "@" then
  local config_dir = source:sub(2):match("(.*/)")
  if config_dir then
    package.path = table.concat({
      config_dir .. "?.lua",
      config_dir .. "?/init.lua",
      package.path,
    }, ";")
  end
end

-- Load the sketchybar-package and prepare the helper binaries
require("helpers")
require("init")
