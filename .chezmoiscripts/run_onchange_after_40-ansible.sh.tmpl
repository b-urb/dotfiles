{{- if eq .chezmoi.os "windows" }}{{ else -}}
#!/bin/bash
# Provision software on this machine via Ansible.
# Triggered automatically whenever any file under ansible/ changes.
#
# ansible dir hash:
# ansible.cfg:     {{ include (joinPath .chezmoi.sourceDir "ansible/ansible.cfg") | sha256sum }}
# local.yml:       {{ include (joinPath .chezmoi.sourceDir "ansible/local.yml") | sha256sum }}
# group_vars:      {{ include (joinPath .chezmoi.sourceDir "ansible/group_vars/all.yml") | sha256sum }}
# common:          {{ include (joinPath .chezmoi.sourceDir "ansible/roles/common/tasks/main.yml") | sha256sum }}
# macos vars:      {{ include (joinPath .chezmoi.sourceDir "ansible/roles/macos/vars/main.yml") | sha256sum }}
# ubuntu tasks:    {{ include (joinPath .chezmoi.sourceDir "ansible/roles/ubuntu/tasks/main.yml") | sha256sum }}
# ubuntu vars:     {{ include (joinPath .chezmoi.sourceDir "ansible/roles/ubuntu/vars/main.yml") | sha256sum }}
# arch tasks:      {{ include (joinPath .chezmoi.sourceDir "ansible/roles/arch/tasks/main.yml") | sha256sum }}
# arch vars:       {{ include (joinPath .chezmoi.sourceDir "ansible/roles/arch/vars/main.yml") | sha256sum }}
# linux_common:    {{ include (joinPath .chezmoi.sourceDir "ansible/roles/linux_common/tasks/main.yml") | sha256sum }}
# wm_linux:        {{ include (joinPath .chezmoi.sourceDir "ansible/roles/wm_linux/tasks/main.yml") | sha256sum }}
# fonts:           {{ include (joinPath .chezmoi.sourceDir "ansible/roles/fonts/tasks/main.yml") | sha256sum }}
# wsl_ubuntu tasks: {{ include (joinPath .chezmoi.sourceDir "ansible/roles/wsl_ubuntu/tasks/main.yml") | sha256sum }}
# wsl_ubuntu vars:  {{ include (joinPath .chezmoi.sourceDir "ansible/roles/wsl_ubuntu/vars/main.yml") | sha256sum }}
# rust:            {{ include (joinPath .chezmoi.sourceDir "ansible/roles/rust/tasks/main.yml") | sha256sum }}
# vscode:          {{ include (joinPath .chezmoi.sourceDir "ansible/roles/vscode_extensions/tasks/main.yml") | sha256sum }}

set -e

PLAYBOOK="{{ joinPath .chezmoi.sourceDir "ansible/local.yml" }}"
ANSIBLE_DIR="{{ joinPath .chezmoi.sourceDir "ansible" }}"
WM_DS="{{ .wmForceDisplayServer | default "" }}"
ENABLE_K8S="{{ .features.enableK8s }}"
IS_WSL="{{ .isWSL | default false }}"

export ANSIBLE_CONFIG="${ANSIBLE_DIR}/ansible.cfg"

# Install Ansible if missing
if ! command -v ansible-playbook &>/dev/null; then
{{ if eq .chezmoi.os "darwin" -}}
    echo "Installing Ansible via Homebrew..."
    brew install ansible
{{ else -}}
    echo "Installing Ansible via pip3..."
    pip3 install --user ansible
    export PATH="$PATH:$HOME/.local/bin"
{{ end -}}
fi

# Install required Ansible collections
# community.general: homebrew, homebrew_cask, pacman, flatpak, flatpak_remote
ansible-galaxy collection install community.general --upgrade

ansible-playbook "$PLAYBOOK" \
    --extra-vars "wm_display_server=${WM_DS}" \
    --extra-vars "enable_k8s=${ENABLE_K8S}" \
    --extra-vars "is_wsl=${IS_WSL}" \
    -v
{{- end }}
