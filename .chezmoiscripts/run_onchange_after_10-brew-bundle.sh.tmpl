#!/bin/bash
# Run `brew bundle` whenever Brewfile changes.
# The hash comment below triggers re-execution when the file content changes.
# Brewfile hash: {{ include "Brewfile" | sha256sum }}

{{ if ne .chezmoi.os "darwin" }}
# Not macOS — skip
exit 0
{{ end -}}

set -e

BREWFILE="{{ joinPath .chezmoi.sourceDir "Brewfile" }}"

if [ ! -f "$BREWFILE" ]; then
    echo "WARNING: Brewfile not found at $BREWFILE, skipping"
    exit 0
fi

echo "=== Running brew bundle ==="
brew bundle --file="$BREWFILE" --no-lock
echo "✓ brew bundle complete"
