#!/bin/bash
# Download kubeconfig attachments from Bitwarden and merge them into ~/.kube/config.
# Triggered when the kubeconfigs Bitwarden item changes (manual re-run) or on first apply.
# To force re-run: `chezmoi state delete-bucket --bucket=scriptState` then `chezmoi apply`

set -e

{{ if not .features.enableK8s }}
echo "K8s disabled (features.enableK8s=false) — skipping kubeconfig merge"
exit 0
{{ end -}}

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}=== Merging kubeconfigs from Bitwarden ===${NC}"

# Require BW_SESSION
if [ -z "$BW_SESSION" ]; then
    echo -e "${RED}ERROR: BW_SESSION not set — cannot fetch kubeconfigs${NC}" >&2
    echo -e "${YELLOW}Run: export BW_SESSION=\$(bw unlock --raw)${NC}" >&2
    exit 1
fi

KUBE_CLUSTERS_DIR="{{ joinPath .chezmoi.sourceDir "kube/clusters" }}"
OUTPUT_DIR="$HOME/.kube"
OUTPUT_FILE="$OUTPUT_DIR/config"

mkdir -p "$OUTPUT_DIR"
mkdir -p "$KUBE_CLUSTERS_DIR"

# ─── Fetch kubeconfig attachments from Bitwarden ────────────────────────────
KUBECONFIG_FOLDER_ID=$(bw list folders --session "$BW_SESSION" 2>/dev/null | \
    jq -r '.[] | select(.name=="dotfiles/kubeconfig") | .id')

if [ -z "$KUBECONFIG_FOLDER_ID" ] || [ "$KUBECONFIG_FOLDER_ID" = "null" ]; then
    echo -e "${YELLOW}WARNING: dotfiles/kubeconfig folder not found in Bitwarden${NC}"
    echo -e "${YELLOW}Run: scripts/setup-bitwarden.sh to create Bitwarden folder structure${NC}"
    exit 0
fi

KUBE_ITEM_ID=$(bw list items --folderid "$KUBECONFIG_FOLDER_ID" --session "$BW_SESSION" 2>/dev/null | \
    jq -r '.[] | select(.name=="kubeconfigs") | .id')

if [ -z "$KUBE_ITEM_ID" ] || [ "$KUBE_ITEM_ID" = "null" ]; then
    echo -e "${YELLOW}No kubeconfigs item found in Bitwarden (OK on first setup)${NC}"
    exit 0
fi

echo -e "${GREEN}Downloading kubeconfig attachments...${NC}"
bw get item "$KUBE_ITEM_ID" --session "$BW_SESSION" | \
    jq -r '.attachments[]? | .id + " " + .fileName' | \
    while read -r attachment_id filename; do
        if [ -n "$attachment_id" ] && [ -n "$filename" ]; then
            echo -e "${GREEN}  Fetching: $filename${NC}"
            bw get attachment "$attachment_id" \
                --itemid "$KUBE_ITEM_ID" \
                --output "$KUBE_CLUSTERS_DIR/$filename" \
                --session "$BW_SESSION" 2>/dev/null
            chmod 600 "$KUBE_CLUSTERS_DIR/$filename"
        fi
    done

# ─── Merge all .yaml kubeconfigs ────────────────────────────────────────────
CONFIGS=""
SEPARATOR=":"

for f in "$KUBE_CLUSTERS_DIR"/*.yaml "$KUBE_CLUSTERS_DIR"/*.yml; do
    [ -f "$f" ] || continue
    CONFIGS="${CONFIGS}${SEPARATOR}${f}"
done

CONFIGS="${CONFIGS#:}"

if [ -z "$CONFIGS" ]; then
    echo -e "${YELLOW}No kubeconfig YAML files found to merge${NC}"
    exit 0
fi

echo -e "${GREEN}Merging kubeconfigs: $CONFIGS${NC}"
KUBECONFIG="$CONFIGS" kubectl config view --merge --flatten > "$OUTPUT_FILE"
chmod 600 "$OUTPUT_FILE"

echo -e "${GREEN}✓ Kubeconfig merged to $OUTPUT_FILE${NC}"
