{{- if eq .chezmoi.os "windows" }}{{ else -}}
#!/bin/bash
# Install core dependencies before dotfiles are applied.
# This script runs once per machine (tracked by content hash).

set -e

{{ if eq .chezmoi.os "darwin" -}}
# ─── macOS: Install Homebrew ────────────────────────────────────────────────
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Ensure brew is on PATH for Apple Silicon
if [ -f /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Install Bitwarden CLI if missing (needed for chezmoi secrets)
if ! command -v bw &>/dev/null; then
    echo "Installing Bitwarden CLI..."
    brew install bitwarden-cli
fi

{{ else if eq .chezmoi.os "linux" -}}
# ─── Linux: Install nvm + Node.js (needed for bw and other npm tools) ───────
export NVM_DIR="$HOME/.nvm"
if [ ! -s "$NVM_DIR/nvm.sh" ]; then
    echo "Installing nvm..."
    curl -fsSL --http1.1 https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
fi
. "$NVM_DIR/nvm.sh"

if ! command -v node &>/dev/null; then
    echo "Installing Node.js LTS..."
    nvm install --lts --default
fi

# ─── Linux: Install chezmoi to ~/.local/bin so it shadows chezmoi.exe ───────
if [ ! -x "$HOME/.local/bin/chezmoi" ]; then
    echo "Installing native chezmoi..."
    sh -c "$(curl -fsLS --http1.1 get.chezmoi.io)" -- -b "$HOME/.local/bin"
fi

# ─── Linux: Install jq (required by kubeconfig merge and other scripts) ─────
if ! command -v jq &>/dev/null; then
    echo "Installing jq..."
    sudo apt-get install -y jq
fi

# ─── Linux: Install Bitwarden CLI if missing ────────────────────────────────
if ! command -v bw &>/dev/null; then
    echo "Installing Bitwarden CLI via npm..."
    npm install -g @bitwarden/cli
fi
{{ end -}}

{{- if .bwServerUrl }}
# ─── Bitwarden server URL ───────────────────────────────────────────────────
current_server=$(bw config server 2>/dev/null || true)
if [ "$current_server" != {{ .bwServerUrl | quote }} ]; then
    echo "Configuring Bitwarden server URL..."
    bw logout 2>/dev/null || true
    bw config server {{ .bwServerUrl | quote }}
fi
{{ end -}}

echo "✓ Dependencies ready"
{{- end }}
