{{- if eq .chezmoi.os "windows" }}{{ else -}}
#!/bin/bash
# Download kubeconfig attachments from Bitwarden and merge them into ~/.kube/config.
# Triggered when the kubeconfigs Bitwarden item changes (manual re-run) or on first apply.
# To force re-run: `chezmoi state delete-bucket --bucket=scriptState` then `chezmoi apply`

set -e

{{ if not .features.enableK8s }}
echo "K8s disabled (features.enableK8s=false) — skipping kubeconfig merge"
exit 0
{{ end -}}

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}=== Merging kubeconfigs from Bitwarden ===${NC}"

# Require BW_SESSION
if [ -z "$BW_SESSION" ]; then
    echo -e "${RED}ERROR: BW_SESSION not set — cannot fetch kubeconfigs${NC}" >&2
    echo -e "${YELLOW}Run: export BW_SESSION=\$(bw unlock --raw)${NC}" >&2
    exit 1
fi

if ! BW_STATUS_JSON=$(bw status --session "$BW_SESSION" 2>&1); then
    echo -e "${RED}ERROR: Failed to check Bitwarden session status${NC}" >&2
    echo "$BW_STATUS_JSON" >&2
    exit 1
fi
if ! BW_STATUS=$(printf '%s' "$BW_STATUS_JSON" | jq -r '.status' 2>&1); then
    echo -e "${RED}ERROR: Unexpected Bitwarden status response${NC}" >&2
    echo "$BW_STATUS" >&2
    echo "$BW_STATUS_JSON" >&2
    exit 1
fi
if [ "$BW_STATUS" != "unlocked" ]; then
    echo -e "${RED}ERROR: Bitwarden vault is $BW_STATUS${NC}" >&2
    echo -e "${YELLOW}Run: export BW_SESSION=\$(bw unlock --raw)${NC}" >&2
    exit 1
fi

echo -e "${GREEN}Syncing Bitwarden...${NC}"
if ! BW_OUTPUT=$(bw sync --session "$BW_SESSION" 2>&1); then
    echo -e "${RED}ERROR: Failed to sync Bitwarden${NC}" >&2
    echo "$BW_OUTPUT" >&2
    exit 1
fi

KUBE_CLUSTERS_DIR="{{ joinPath .chezmoi.sourceDir "kube/clusters" }}"

mkdir -p "$KUBE_CLUSTERS_DIR"

# ─── Fetch kubeconfig attachments from Bitwarden ────────────────────────────
if ! FOLDERS_JSON=$(bw list folders --session "$BW_SESSION" 2>&1); then
    echo -e "${RED}ERROR: Failed to list Bitwarden folders${NC}" >&2
    echo "$FOLDERS_JSON" >&2
    exit 1
fi
if ! KUBECONFIG_FOLDER_ID=$(printf '%s' "$FOLDERS_JSON" | jq -r '.[] | select(.name=="dotfiles/kubeconfig") | .id' 2>&1); then
    echo -e "${RED}ERROR: Unexpected response while listing Bitwarden folders${NC}" >&2
    echo "$KUBECONFIG_FOLDER_ID" >&2
    echo "$FOLDERS_JSON" >&2
    exit 1
fi

if [ -z "$KUBECONFIG_FOLDER_ID" ] || [ "$KUBECONFIG_FOLDER_ID" = "null" ]; then
    echo -e "${YELLOW}WARNING: dotfiles/kubeconfig folder not found in Bitwarden${NC}"
    echo -e "${YELLOW}Run: scripts/setup-bitwarden.sh to create Bitwarden folder structure${NC}"
    exit 0
fi

if ! KUBE_ITEMS_JSON=$(bw list items --folderid "$KUBECONFIG_FOLDER_ID" --session "$BW_SESSION" 2>&1); then
    echo -e "${RED}ERROR: Failed to list kubeconfig items from Bitwarden${NC}" >&2
    echo "$KUBE_ITEMS_JSON" >&2
    exit 1
fi
if ! KUBE_ITEM_ID=$(printf '%s' "$KUBE_ITEMS_JSON" | jq -r '.[] | select(.name=="kubeconfigs") | .id' 2>&1); then
    echo -e "${RED}ERROR: Unexpected response while listing kubeconfig items${NC}" >&2
    echo "$KUBE_ITEM_ID" >&2
    echo "$KUBE_ITEMS_JSON" >&2
    exit 1
fi

if [ -z "$KUBE_ITEM_ID" ] || [ "$KUBE_ITEM_ID" = "null" ]; then
    echo -e "${YELLOW}No kubeconfigs item found in Bitwarden (OK on first setup)${NC}"
    exit 0
fi

echo -e "${GREEN}Downloading kubeconfig attachments...${NC}"
if ! KUBE_ITEM_JSON=$(bw get item "$KUBE_ITEM_ID" --session "$BW_SESSION" 2>&1); then
    echo -e "${RED}ERROR: Failed to fetch kubeconfigs item from Bitwarden${NC}" >&2
    echo "$KUBE_ITEM_JSON" >&2
    exit 1
fi
if ! ATTACHMENTS=$(printf '%s' "$KUBE_ITEM_JSON" | jq -r '.attachments[]? | [.id, .fileName] | @tsv' 2>&1); then
    echo -e "${RED}ERROR: Unexpected kubeconfigs item response from Bitwarden${NC}" >&2
    echo "$ATTACHMENTS" >&2
    echo "$KUBE_ITEM_JSON" >&2
    exit 1
fi

while IFS=$'\t' read -r attachment_id filename; do
    if [ -n "$attachment_id" ] && [ "$attachment_id" != "null" ] && [ -n "$filename" ] && [ "$filename" != "null" ]; then
        echo -e "${GREEN}  Fetching: $filename${NC}"
        tmp_file="$(mktemp "$KUBE_CLUSTERS_DIR/.kubeconfig.XXXXXX")"
        if ! BW_OUTPUT=$(bw get attachment "$attachment_id" \
            --itemid "$KUBE_ITEM_ID" \
            --output "$tmp_file" \
            --session "$BW_SESSION" 2>&1); then
            echo -e "${YELLOW}  Attachment id failed for $filename; syncing and retrying by filename...${NC}"
            rm -f "$tmp_file"
            if ! SYNC_OUTPUT=$(bw sync --session "$BW_SESSION" 2>&1); then
                echo -e "${RED}ERROR: Failed to sync Bitwarden before retrying '$filename'${NC}" >&2
                echo "$SYNC_OUTPUT" >&2
                exit 1
            fi
            tmp_file="$(mktemp "$KUBE_CLUSTERS_DIR/.kubeconfig.XXXXXX")"
            if ! RETRY_OUTPUT=$(bw get attachment "$filename" \
                --itemid "$KUBE_ITEM_ID" \
                --output "$tmp_file" \
                --session "$BW_SESSION" 2>&1); then
                rm -f "$tmp_file"
                if [[ "$BW_OUTPUT$RETRY_OUTPUT" == *"Attachment doesn't exist"* ]]; then
                    echo -e "${YELLOW}  Removing stale Bitwarden attachment entry: $filename${NC}"
                    if ! CLEANUP_OUTPUT=$(bw delete attachment "$attachment_id" --itemid "$KUBE_ITEM_ID" --session "$BW_SESSION" 2>&1); then
                        echo -e "${YELLOW}  Could not remove stale attachment entry; skipping: $filename${NC}" >&2
                        echo "$CLEANUP_OUTPUT" >&2
                    else
                        bw sync --session "$BW_SESSION" >/dev/null 2>&1 || true
                    fi
                    rm -f "$KUBE_CLUSTERS_DIR/$filename"
                    continue
                fi
                echo -e "${RED}ERROR: Failed to download kubeconfig attachment '$filename'${NC}" >&2
                echo "First attempt by attachment id:" >&2
                echo "$BW_OUTPUT" >&2
                echo "Retry by filename after sync:" >&2
                echo "$RETRY_OUTPUT" >&2
                exit 1
            fi
        fi
        chmod 600 "$tmp_file"
        mv "$tmp_file" "$KUBE_CLUSTERS_DIR/$filename"
    fi
done <<< "$ATTACHMENTS"

echo -e "${GREEN}Merging kubeconfigs...${NC}"
bash "$KUBE_CLUSTERS_DIR/merge_clusters.sh"

echo -e "${GREEN}✓ Kubeconfig merged to {{ joinPath .chezmoi.sourceDir "kube/config" }}${NC}"
{{- end }}
